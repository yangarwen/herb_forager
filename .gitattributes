# Normalize all text to LF in the repo and on checkout (consistent across Windows/macOS)
* text=auto eol=lf

# Source / config (explicit)
*.cs        text diff=csharp
*.shader    text
*.cginc     text
*.hlsl      text
*.json      text
*.md        text
*.txt       text
*.xml       text
*.yml       text
*.js        text
*.html      text
*.css       text
*.mjs       text
*.bat       text eol=crlf

# Unity YAML assets — enable smart merge (falls back to default if tool not configured)
*.meta            text merge=unityyamlmerge eol=lf
*.unity           text merge=unityyamlmerge eol=lf
*.asset           text merge=unityyamlmerge eol=lf
*.prefab          text merge=unityyamlmerge eol=lf
*.mat             text merge=unityyamlmerge eol=lf
*.controller      text merge=unityyamlmerge eol=lf
*.anim            text merge=unityyamlmerge eol=lf
*.physicMaterial  text merge=unityyamlmerge eol=lf
*.inputactions    text
*.wlt             text

# Binary assets (never normalize / diff)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.psd  binary
*.tga  binary
*.fbx  binary
*.obj  binary
*.blend binary
*.wav  binary
*.mp3  binary
*.ogg  binary
*.ttf  binary
*.otf  binary
*.dll  binary
*.unitypackage binary
